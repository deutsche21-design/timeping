# Dependencies
node_modules/

# Build output (uploaded as Release assets, not in repo)
dist/

# Bundled main script — generated by `npm run bundle`, not source.
# Contains compiled config secrets, must NOT be in repo.
main.bundle.js

# OS / editor cruft
.DS_Store
*.log
.vscode/
.idea/

# Local env / secrets
.env
.env.*
!.env.example

# OAuth credentials — embedded in binaries but NOT in public repo.
# Copy src/config.example.json → src/config.json and fill in your own values
# from Google Cloud Console (https://console.cloud.google.com/apis/credentials).
src/config.json

# Backup data
*.bak
